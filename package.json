{
  "name": "circlehack",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run dev:server",
    "dev:server": "bun run --cwd apps/server dev",
    "dev:sdk": "bun run --cwd packages/arcade-sdk dev",
    "dev:game": "bun run --cwd apps/game dev",
    "build": "bun run --cwd packages/arcade-sdk build && bun run --cwd apps/server build && bun run --cwd apps/game build",
    "demo": "bun run --cwd apps/server dev"
  },
  "devDependencies": {
    "bun-types": "latest",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@circle-fin/x402-batching": "^3.0.2",
    "@x402/core": "^2.10.0",
    "@x402/evm": "^2.10.0",
    "viem": "^2.48.4"
  }
}
